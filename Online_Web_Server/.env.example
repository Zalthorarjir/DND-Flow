# Online Web Server - Environment Configuration

# Discord OAuth2 settings for website login
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=https://your-domain-or-ip/callback

# Optional: override OAuth scope if you need more than basic identity
DISCORD_OAUTH_SCOPE=identify

# Public bind and URL settings
ONLINE_WEB_SERVER_HOST=0.0.0.0
ONLINE_WEB_SERVER_PORT=5000
PUBLIC_BASE_URL=https://your-domain-or-ip

# Optional: direct TLS certificate files for HTTPS on Flask itself
ONLINE_WEB_SERVER_SSL_CERT=/path/to/fullchain.pem
ONLINE_WEB_SERVER_SSL_KEY=/path/to/privkey.pem

# Enable only when you run behind a reverse proxy that forwards host/proto headers
TRUST_PROXY_HEADERS=False

# Flask secret key for session management
# Generate a random secure key or use the default
# To generate: python -c "import secrets; print(secrets.token_hex(16))"
FLASK_SECRET_KEY=your-secret-key-change-me

# Flask debug mode (set to False for production)
FLASK_ENV=production
FLASK_DEBUG=False
